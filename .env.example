# ============================================================
# Server
# ============================================================
PORT=8080

# ============================================================
# Database
# ============================================================
DB_URL=jdbc:h2:mem:quantitydb
DB_USERNAME=sa
DB_PASSWORD=

H2_CONSOLE_ENABLED=false
JPA_SHOW_SQL=false

# ============================================================
# JWT
# ============================================================
JWT_SECRET=your-super-secret-key-minimum-32-characters-long
JWT_EXPIRATION_MS=86400000

# ============================================================
# Google OAuth2
# ============================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth2 redirect URI registered in Google Cloud Console
OAUTH2_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google

# Frontend URL to redirect after OAuth2 success
FRONTEND_REDIRECT_URL=http://localhost:4200/oauth2/callback

# ============================================================
# Actuator
# ============================================================
ACTUATOR_ENDPOINTS=health,info
